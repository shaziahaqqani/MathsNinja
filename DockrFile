# Tomcat 10.1 (Jakarta EE support ke liye) ka use karenge
FROM tomcat:10.1-jdk17-openjdk-slim

# Purane default apps ko remove karne ke liye
RUN rm -rf /usr/local/tomcat/webapps/*

# 1. Java Classes (Compiled code) ko copy karein
# Aapke project mein build hone ke baad classes yahan honi chahiye
COPY build/classes /usr/local/tomcat/webapps/ROOT/WEB-INF/classes/

# 2. Web Content (JSP, CSS, WEB-INF) ko copy karein
# Aapka structure: src/main/webapp/
COPY src/main/webapp/ /usr/local/tomcat/webapps/ROOT/

# 3. Agar koi external JARs hain (lib folder mein)
# COPY lib/*.jar /usr/local/tomcat/webapps/ROOT/WEB-INF/lib/

EXPOSE 8080

CMD ["catalina.sh", "run"]
